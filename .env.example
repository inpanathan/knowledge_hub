# Application environment: dev | staging | production | test
APP_ENV=dev
APP_DEBUG=true

# Secret key — CHANGE THIS in staging/production
SECRET_KEY=CHANGE-ME-IN-PRODUCTION

# Model backend: mock | local | cloud
MODEL_BACKEND=mock

# Set to true to use mock implementations for external services
USE_MOCKS=true

# API keys (add your project-specific keys here)
# LLM_API_KEY=
# EMBEDDING_API_KEY=

# Embedding model
# EMBEDDING__MODEL_NAME=BAAI/bge-large-en-v1.5
# EMBEDDING__DIMENSION=1024

# vLLM (local GPU inference)
# LLM__VLLM_BASE_URL=http://localhost:8000/v1
# LLM__VLLM_MODEL=Qwen/Qwen2.5-14B-Instruct

# Qdrant vector store
# VECTOR_STORE__URL=http://localhost:6333

# Logging
LOGGING__LEVEL=DEBUG
LOGGING__FORMAT=console
