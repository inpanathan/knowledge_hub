.DS_Store
Thumbs.db

# Script runtime files (pid + log for backgrounded processes)
.*.pid
.*.log

# Uploaded files (runtime, not tracked)
data/uploads/

# Qdrant persistent storage (runtime, not tracked)
data/qdrant_storage/
data/vectorstore/

# SQLite databases (runtime, not tracked)
data/catalog.db

# Book originals (runtime, not tracked)
data/originals/

